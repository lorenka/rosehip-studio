---
import ContactCTA from '../../components/ContactCTA.astro';
import Hero from '../../components/Hero.astro';
import Icon from '../../components/Icon.astro';
import Pill from '../../components/Pill.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GardenDemo from '../../components/GardenDemo.jsx';
---

<BaseLayout
	title="What's Growing Here | Rosehip Studio"
	description="A Next.js and Supabase plant cataloging platform for homeowners and landscapers — catalog gardens, autocomplete Latin names, and share with QR codes."
>
	<div class="stack gap-20">
		<div class="stack gap-15">
			<header>
				<div class="wrapper stack gap-2">
					<a class="back-link" href="/work/"><Icon icon="arrow-left" /> Work</a>
					<Hero title="What's Growing Here" align="start">
						<div class="details">
							<div class="tags">
								<Pill>Next.js</Pill>
								<Pill>Supabase</Pill>
								<Pill>Product</Pill>
							</div>
							<p class="description">
								A plant cataloging platform for homeowners and landscapers —
								create gardens, autocomplete botanical names, and share
								collections with QR codes.
							</p>
						</div>
					</Hero>
				</div>
			</header>
			<main class="wrapper">
				<div class="stack gap-10 content">
					<p>
						<a href="https://whatsgrowinghere.com">What's Growing Here</a> is a
						full-stack product built with Next.js 15, TypeScript, and Supabase
						(PostgreSQL with row-level security), deployed to Cloudflare. Users
						sign in with Google, build gardens plant by plant with
						Latin-name autocomplete backed by the GBIF species API, and publish
						any garden to a public page with its own QR code — handy for a
						sign at the garden gate.
					</p>
					<img
						src="/assets/whats-growing-here.jpg"
						alt="What's Growing Here app showing a garden's plant list with photos and Latin names"
						loading="lazy"
					/>
					<p>
						The demo below is a miniature of the core flow, running entirely in
						your browser: search the app's real 96-vegetable seed catalog and
						plant your picks in a demo garden. The full app adds accounts,
						photos, multiple gardens, and sharing —
						<a href="https://whatsgrowinghere.com">try it live</a>.
					</p>
					<GardenDemo client:load />
				</div>
			</main>
		</div>
		<ContactCTA />
	</div>
</BaseLayout>

<style>
	header {
		padding-bottom: 2.5rem;
		border-bottom: 1px solid var(--gray-800);
	}

	.back-link {
		display: none;
	}

	.details {
		display: flex;
		flex-direction: column;
		padding: 0.5rem;
		gap: 1.5rem;
		justify-content: space-between;
		align-items: center;
	}

	.tags {
		display: flex;
		gap: 0.5rem;
	}

	.description {
		font-size: var(--text-lg);
		max-width: 54ch;
	}

	.content {
		max-width: 800px;
		margin-inline: auto;
	}

	.content > :global(* + *) {
		margin-top: 1rem;
	}

	.content img {
		border-radius: 1.5rem;
		box-shadow: var(--shadow-md);
		max-width: 100%;
		height: auto;
	}

	.content :global(a) {
		text-decoration: 1px solid underline transparent;
		text-underline-offset: 0.25em;
		transition: text-decoration-color var(--theme-transition);
	}

	.content :global(a:hover),
	.content :global(a:focus) {
		text-decoration-color: currentColor;
	}

	@media (min-width: 50em) {
		.back-link {
			display: block;
			align-self: flex-start;
		}

		.details {
			flex-direction: row;
			gap: 2.5rem;
		}
	}
</style>
